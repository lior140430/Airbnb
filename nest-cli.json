{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/auth-service/src",
  "monorepo": true,
  "root": "apps/auth-service",
  "compilerOptions": {
    "webpack": false,
    "tsLoader": {
      "transpileOnly": true
    }
  },
  "projects": {
    "auth-service": {
      "type": "application",
      "root": "apps/auth-service",
      "entryFile": "main",
      "sourceRoot": "apps/auth-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth-service/tsconfig.json"
      }
    },
    "property-service": {
      "type": "application",
      "root": "apps/property-service",
      "entryFile": "main",
      "sourceRoot": "apps/property-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/property-service/tsconfig.json"
      }
    }
  }
}
